<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI 主管 · 问答助手</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
            background-color: #08090a;
            color: #c9cdd5;
            line-height: 1.6;
            min-height: 100vh;
        }

        /* ==================== 顶部导航 ==================== */
        .top-nav {
            background: #0d0e10;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            padding: 0 32px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(12px);
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 32px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: white;
            font-weight: 600;
            font-size: 15px;
        }

        .logo-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, #5e6ad2 0%, #7c7fe8 100%);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: bold;
            color: white;
        }

        .nav-links {
            display: flex;
            gap: 4px;
        }

        .nav-link {
            padding: 6px 14px;
            border-radius: 6px;
            color: #8b8f98;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .nav-link:hover {
            color: #c9cdd5;
            background: rgba(255,255,255,0.06);
        }

        .nav-link.active {
            color: white;
            background: rgba(94,106,210,0.15);
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .search-box {
            position: relative;
            width: 240px;
        }

        .search-box input {
            width: 100%;
            padding: 7px 12px 7px 32px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #c9cdd5;
            font-size: 13px;
            transition: all 0.2s;
        }

        .search-box input:focus {
            outline: none;
            border-color: #5e6ad2;
            background: rgba(94,106,210,0.08);
            box-shadow: 0 0 0 3px rgba(94,106,210,0.15);
        }

        .search-box input::placeholder {
            color: #5e636d;
        }

        .search-box .search-icon {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #5e636d;
            font-size: 14px;
        }

        .search-box .kbd-hint {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.08);
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 11px;
            color: #5e636d;
            font-family: monospace;
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #5e6ad2 0%, #e879a8 100%);
            cursor: pointer;
            transition: transform 0.2s;
        }

        .avatar:hover {
            transform: scale(1.05);
        }

        /* ==================== Hero 区 ==================== */
        .hero {
            max-width: 720px;
            margin: 0 auto;
            padding: 80px 24px 48px;
            text-align: center;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(94,106,210,0.12);
            border: 1px solid rgba(94,106,210,0.25);
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 13px;
            color: #8b8ff5;
            margin-bottom: 24px;
            font-weight: 500;
        }

        .badge-dot {
            width: 6px;
            height: 6px;
            background: #8b8ff5;
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        .hero h1 {
            font-size: 48px;
            font-weight: 700;
            color: white;
            margin-bottom: 16px;
            letter-spacing: -0.02em;
            line-height: 1.1;
        }

        .hero p {
            font-size: 17px;
            color: #5e636d;
            margin-bottom: 40px;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
        }

        .hero-search {
            position: relative;
            max-width: 560px;
            margin: 0 auto;
        }

        .hero-search textarea {
            width: 100%;
            min-height: 120px;
            padding: 18px 20px;
            background: #0d0e10;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            color: #c9cdd5;
            font-size: 15px;
            line-height: 1.7;
            resize: vertical;
            transition: all 0.2s;
            font-family: inherit;
        }

        .hero-search textarea:focus {
            outline: none;
            border-color: #5e6ad2;
            box-shadow: 0 0 0 3px rgba(94,106,210,0.15);
        }

        .hero-search textarea::placeholder {
            color: #5e636d;
        }

        .hero-search-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 12px;
        }

        .search-hint {
            font-size: 13px;
            color: #5e636d;
        }

        .search-hint kbd {
            background: rgba(255,255,255,0.08);
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 12px;
            font-family: monospace;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .btn-primary {
            background: #5e6ad2;
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary:hover {
            background: #6c70d8;
            transform: translateY(-1px);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .btn-primary:disabled {
            background: #3d4060;
            cursor: not-allowed;
            transform: none;
        }

        /* ==================== 输出区 ==================== */
        .output-section {
            max-width: 720px;
            margin: 0 auto 48px;
            padding: 0 24px;
            display: none;
        }

        .output-section.active {
            display: block;
        }

        .output-card {
            background: #0d0e10;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 24px;
        }

        .output-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .output-title {
            font-size: 14px;
            font-weight: 600;
            color: white;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .source-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: rgba(94,106,210,0.12);
            color: #8b8ff5;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
        }

        .reply-content {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 8px;
            padding: 18px;
            min-height: 120px;
            font-size: 14px;
            line-height: 1.8;
            color: #c9cdd5;
            margin-bottom: 16px;
            white-space: pre-wrap;
        }

        .btn-copy {
            background: #5e6ad2;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-copy:hover {
            background: #6c70d8;
            transform: translateY(-1px);
        }

        .btn-copy.copied {
            background: #3d7a52;
        }

        /* ==================== 分类卡片 ==================== */
        .categories {
            max-width: 960px;
            margin: 0 auto;
            padding: 0 24px 64px;
        }

        .categories-title {
            font-size: 14px;
            font-weight: 600;
            color: #5e636d;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 16px;
        }

        .category-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .category-card {
            background: #0d0e10;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            padding: 20px;
            transition: all 0.2s;
            cursor: pointer;
            display: flex;
            align-items: flex-start;
            gap: 16px;
        }

        .category-card:hover {
            background: #13141a;
            border-color: rgba(94,106,210,0.3);
            transform: translateY(-2px);
        }

        .category-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: rgba(94,106,210,0.08);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .category-card:hover .category-icon {
            background: rgba(94,106,210,0.15);
        }

        .category-info h3 {
            font-size: 14px;
            font-weight: 600;
            color: white;
            margin-bottom: 4px;
        }

        .category-info p {
            font-size: 13px;
            color: #5e636d;
            line-height: 1.5;
        }

        /* ==================== 历史记录 ==================== */
        .history-section {
            max-width: 720px;
            margin: 0 auto 48px;
            padding: 0 24px;
        }

        .history-title {
            font-size: 13px;
            font-weight: 600;
            color: #5e636d;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 12px;
        }

        .history-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .history-item {
            background: #0d0e10;
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 8px;
            padding: 12px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            transition: all 0.2s;
        }

        .history-item:hover {
            background: #13141a;
            border-color: rgba(94,106,210,0.2);
        }

        .history-question {
            font-size: 14px;
            color: #c9cdd5;
            flex: 1;
            margin-right: 16px;
        }

        .history-time {
            font-size: 12px;
            color: #5e636d;
            white-space: nowrap;
        }

        /* ==================== 搜索高亮 ==================== */
        .highlight {
            background: rgba(94,106,210,0.25);
            border-radius: 2px;
            padding: 0 2px;
        }

        /* ==================== Loading ==================== */
        .loading {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .spinner {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(139,143,245,0.3);
            border-top-color: #8b8ff5;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ==================== Responsive ==================== */
        @media (max-width: 768px) {
            .top-nav {
                padding: 0 16px;
            }

            .nav-links {
                display: none;
            }

            .search-box {
                width: 180px;
            }

            .hero {
                padding: 48px 16px 32px;
            }

            .hero h1 {
                font-size: 32px;
            }

            .category-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- 顶部导航 -->
    <nav class="top-nav">
        <div class="nav-left">
            <a href="#" class="logo">
                <div class="logo-icon">AI</div>
                <span>AI 主管</span>
            </a>
            <div class="nav-links">
                <a href="#" class="nav-link active">问答助手</a>
                <a href="知识库.html" class="nav-link">话术库</a>
                <a href="#" class="nav-link">样件指南</a>
            </div>
        </div>
        <div class="nav-right">
            <div class="search-box">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="搜索知识库..." id="navSearch">
                <span class="kbd-hint">⌘K</span>
            </div>
            <div class="avatar"></div>
        </div>
    </nav>

    <!-- Hero 区 -->
    <div class="hero">
        <div class="badge">
            <span class="badge-dot"></span>
            知识库已就绪 · 5 类知识库已加载
        </div>
        <h1>AI 主管问答助手</h1>
        <p>粘贴用户问题，AI 根据知识库自动生成专业回复，一键复制给用户</p>

        <div class="hero-search">
            <textarea id="userQuestion" placeholder="这里粘贴用户的问题，例如：客户说"包装破了怎么办"..." rows="4"></textarea>
            <div class="hero-search-footer">
                <span class="search-hint">按 <kbd>⌘</kbd> + <kbd>Enter</kbd> 快速提问</span>
                <button class="btn-primary" onclick="askAI()" id="askBtn">
                    让 AI 主管回答
                </button>
            </div>
        </div>
    </div>

    <!-- 输出区 -->
    <div class="output-section" id="outputSection">
        <div class="output-card">
            <div class="output-header">
                <div class="output-title">
                    🤖 AI 主管回复
                </div>
                <div class="source-tag">
                    📚 <span id="sourceType">标准问答库</span>
                </div>
            </div>
            <div class="reply-content" id="aiReply">AI 正在思考中...</div>
            <button class="btn-copy" onclick="copyReply()" id="copyBtn">
                📋 一键复制回复
            </button>
        </div>
    </div>

    <!-- 历史记录 -->
    <div class="history-section" id="historySection" style="display: none;">
        <div class="history-title">最近会话</div>
        <div class="history-list" id="historyList"></div>
    </div>

    <!-- 分类卡片 -->
    <div class="categories">
        <div class="categories-title">知识库分类</div>
        <div class="category-grid">
            <div class="category-card" onclick="fillExample('风险红线库')">
                <div class="category-icon">🚫</div>
                <div class="category-info">
                    <h3>风险红线库</h3>
                    <p>绝对禁止的回复内容，涉及法律、合规、品牌风险</p>
                </div>
            </div>
            <div class="category-card" onclick="fillExample('标准问答库')">
                <div class="category-icon">📚</div>
                <div class="category-info">
                    <h3>标准问答库</h3>
                    <p>高频问题的标准回复模板，覆盖 80% 常见咨询</p>
                </div>
            </div>
            <div class="category-card" onclick="fillExample('流程指引库')">
                <div class="category-icon">📋</div>
                <div class="category-info">
                    <h3>流程指引库</h3>
                    <p>退货、退款、换货等操作步骤的详细指引</p>
                </div>
            </div>
            <div class="category-card" onclick="fillExample('活动规则库')">
                <div class="category-icon">🎯</div>
                <div class="category-info">
                    <h3>活动规则库</h3>
                    <p>促销活动、优惠券、会员权益的规则说明</p>
                </div>
            </div>
            <div class="category-card" onclick="fillExample('疑难沉淀库')">
                <div class="category-icon">💡</div>
                <div class="category-info">
                    <h3>疑难沉淀库</h3>
                    <p>复杂问题的处理经验和升级判断标准</p>
                </div>
            </div>
            <div class="category-card" onclick="fillExample('升级条件')">
                <div class="category-icon">⚠️</div>
                <div class="category-info">
                    <h3>升级条件</h3>
                    <p>触发人工介入的 5 类条件判断</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        let history = [];
        let currentReply = '';

        // ⌘K 快捷键聚焦搜索
        document.addEventListener('keydown', function(e) {
            if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                e.preventDefault();
                document.getElementById('navSearch').focus();
            }

            if (e.key === 'Escape') {
                document.getElementById('navSearch').blur();
                document.getElementById('userQuestion').focus();
            }

            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                e.preventDefault();
                askAI();
            }
        });

        // AI 回答
        async function askAI() {
            const question = document.getElementById('userQuestion').value.trim();

            if (!question) {
                alert('请先粘贴用户的问题！');
                return;
            }

            document.getElementById('outputSection').classList.add('active');

            const askBtn = document.getElementById('askBtn');
            const originalText = askBtn.innerHTML;
            askBtn.innerHTML = '<span class="loading"><span class="spinner"></span>AI 思考中...</span>';
            askBtn.disabled = true;

            document.getElementById('aiReply').textContent = '正在根据知识库生成回复...';

            try {
                await new Promise(resolve => setTimeout(resolve, 1500));

                const reply = generateMockReply(question);
                currentReply = reply.text;
                document.getElementById('aiReply').textContent = reply.text;
                document.getElementById('sourceType').textContent = reply.source;

                addToHistory(question);

            } catch (error) {
                document.getElementById('aiReply').textContent = '抱歉，AI 暂时无法回复，请稍后重试。';
            } finally {
                askBtn.innerHTML = originalText;
                askBtn.disabled = false;
            }
        }

        // 模拟回复
        function generateMockReply(question) {
            const lowerQ = question.toLowerCase();

            if (lowerQ.includes('包装破') || lowerQ.includes('破损') || lowerQ.includes('损坏')) {
                return {
                    text: '非常抱歉给您带来不好的购物体验！针对您反馈的商品包装破损问题，建议您按以下步骤操作：\n\n1️⃣ 请立即拍摄商品及包装的清晰照片（包含快递单号和破损部位）\n2️⃣ 联系在线客服或拨打客服热线进行登记\n3️⃣ 我们会在 24 小时内为您安排补发或退款处理\n\n同时我们会将此问题反馈至物流部门，加强包装保护措施。再次向您致歉！',
                    source: '标准问答库'
                };
            }

            if (lowerQ.includes('退货') || lowerQ.includes('退款') || lowerQ.includes('退换')) {
                return {
                    text: '关于您的退换货需求，请参考以下流程：\n\n📦 退货条件：\n• 商品保持原包装完好，不影响二次销售\n• 凭购买凭证在 7 天内申请\n\n🔄 操作步骤：\n1. 进入"我的订单" → 选择对应商品\n2. 点击"申请售后" → 选择"退货退款"\n3. 填写原因并提交申请\n4. 等待客服审核（1-2 个工作日）\n\n💡 温馨提示：部分特殊商品不支持 7 天无理由退换。',
                    source: '流程指引库'
                };
            }

            if (lowerQ.includes('发货') || lowerQ.includes('物流') || lowerQ.includes('快递')) {
                return {
                    text: '关于物流查询，您可以通过以下方式获取最新信息：\n\n📍 查询渠道：\n• 进入"我的订单"查看物流轨迹\n• 使用运单号在物流公司官网查询\n\n⏰ 发货时效：\n• 工作日 17 点前下单当天发货\n• 周末/节假日顺延至下一工作日\n\n📞 如遇异常请联系客服协助处理！',
                    source: '标准问答库'
                };
            }

            if (lowerQ.includes('优惠') || lowerQ.includes('折扣') || lowerQ.includes('活动')) {
                return {
                    text: '感谢您关注我们的优惠活动！当前热门活动：\n\n🔥 进行中：\n• 新人专享：首单立减 20 元\n• 满减活动：满 199 减 30，满 399 减 80\n• 会员日：每月 8 日会员享 9 折\n\n📌 使用说明：\n• 优惠券可在结算页自动抵扣\n• 部分特价商品不可叠加使用\n\n需要了解特定活动详情吗？',
                    source: '活动规则库'
                };
            }

            return {
                text: `感谢您的咨询！关于您提到的问题，我会根据知识库为您提供专业建议。\n\n为了更好地帮助您，建议您提供更多细节：\n• 具体情况描述\n• 相关订单号或凭证\n• 期望的解决方案\n\n我会根据您提供的信息给出最准确的回复。如情况复杂，我会及时升级至人工处理。`,
                source: '疑难沉淀库'
            };
        }

        // 复制回复
        async function copyReply() {
            if (!currentReply) {
                alert('暂无可复制的回复内容');
                return;
            }

            try {
                await navigator.clipboard.writeText(currentReply);
                const copyBtn = document.getElementById('copyBtn');
                copyBtn.textContent = '✅ 已复制！';
                copyBtn.classList.add('copied');

                setTimeout(() => {
                    copyBtn.textContent = '📋 一键复制回复';
                    copyBtn.classList.remove('copied');
                }, 2000);
            } catch (err) {
                const textArea = document.createElement('textarea');
                textArea.value = currentReply;
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand('copy');
                document.body.removeChild(textArea);
                alert('已复制到剪贴板！');
            }
        }

        // 历史记录
        function addToHistory(question) {
            if (history.some(item => item.question === question)) return;

            history.unshift({ question, time: new Date().toLocaleTimeString() });
            if (history.length > 10) history.pop();

            renderHistory();
        }

        function escapeHtml(str) {
            const div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }

        function renderHistory() {
            const section = document.getElementById('historySection');
            const list = document.getElementById('historyList');

            if (history.length === 0) {
                section.style.display = 'none';
                return;
            }

            section.style.display = 'block';
            list.innerHTML = history.map((item, index) => `
                <div class="history-item" onclick="loadHistory(${index})">
                    <span class="history-question">${escapeHtml(item.question)}</span>
                    <span class="history-time">${escapeHtml(item.time)}</span>
                </div>
            `).join('');
        }

        function loadHistory(index) {
            document.getElementById('userQuestion').value = history[index].question;
            document.getElementById('userQuestion').focus();
        }

        function fillExample(type) {
            const examples = {
                '风险红线库': '你们卖的东西是假货吧？我要投诉你们！',
                '标准问答库': '包装破了怎么办？',
                '流程指引库': '我想退货，怎么操作？',
                '活动规则库': '有什么优惠活动吗？',
                '疑难沉淀库': '这个产品和其他品牌比有什么优势？',
                '升级条件': '你们这是什么态度？我要找你们领导！'
            };

            document.getElementById('userQuestion').value = examples[type] || '';
            document.getElementById('userQuestion').focus();
        }

        // 搜索高亮
        document.getElementById('navSearch').addEventListener('input', function(e) {
            const query = e.target.value.toLowerCase();
            if (!query) return;

            document.querySelectorAll('.category-card').forEach(card => {
                const text = card.textContent.toLowerCase();
                if (text.includes(query)) {
                    card.style.borderColor = 'rgba(94,106,210,0.5)';
                } else {
                    card.style.borderColor = 'rgba(255,255,255,0.08)';
                }
            });
        });
    </script>
</body>
</html>
